ENV=dev
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
SQLITE_PATH=:memory:
EMBEDDING_BACKEND=auto
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
NER_BACKEND=auto
TOKENIZER_BACKEND=auto
TOKENIZER_MODEL=gpt-4o-mini

# Optional persistent audit/governance storage.
# Use SQLite for local smoke tests:
# MEMORY_DATABASE_URL=sqlite:///data/omni_memory.db
# Use Postgres in product deployments:
# MEMORY_DATABASE_URL=postgresql+psycopg://omni:omni@localhost:5432/omni_memory
MEMORY_AUDIT_ENABLED=false
MEMORY_AUDIT_AUTO_CREATE=false
MEMORY_AUDIT_DEFAULT_LIMIT=50
